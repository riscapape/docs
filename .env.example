# =============================================================================
# P2P Foundation Documentation – Environment configuration
# =============================================================================
# Copy this file to .env and set values for your environment.
# Used by: Docusaurus (frontend build) and Knowledge API (backend).
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend (Docusaurus) – set when building the docs site
# -----------------------------------------------------------------------------
# Backend API URL. When the backend runs on a different server, set this to
# that server’s public URL so the built site calls the correct API.
# Examples:
#   Local:    http://localhost:3001
#   Deployed: https://api.docs.p2p.me  or  https://your-backend.example.com
KNOWLEDGE_API_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Backend (Knowledge API) – set when running or deploying the API server
# -----------------------------------------------------------------------------
# Port the API listens on
PORT=3001

# Ollama base URL (where the LLM runs). In Docker Compose use the service name.
# Examples: http://localhost:11434  or  http://ollama:11434
OLLAMA_HOST=http://localhost:11434

# LLM model name (must be pulled in Ollama: ollama pull <model>)
LLM_MODEL=llama3.1

# Allowed CORS origins. Required when frontend is on a different host.
# Comma-separated list, or * to allow all (not recommended in production).
# Examples:
#   Same machine:  http://localhost:3000,http://127.0.0.1:3000
#   Production:    https://docs.p2p.me,https://docs.example.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Path to knowledge-db.json. Leave unset to use default (app dir).
# Set in Docker/deploy if the DB is on a volume.
# KNOWLEDGE_DB_PATH=/data/knowledge-db.json

# Repository root for ingest (optional). Set if running ingest from a path
# where relative resolution would be wrong.
# REPO_ROOT=/app

# Node environment
NODE_ENV=development

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# ASK_AI_PROJECT_ID=your-project-id
